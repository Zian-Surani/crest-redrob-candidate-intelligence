# Copy to .env for local development. Never commit the populated .env file.
CREST_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CREST_TOKEN_SECRET=replace-with-a-long-random-development-secret
CREST_TOKEN_TTL_SECONDS=86400
CREST_BOOTSTRAP_DEMO=false

# Ollama is advisory only and never changes competition ranks.
CREST_OLLAMA_ENABLED=true
CREST_OLLAMA_URL=http://127.0.0.1:11434
CREST_OLLAMA_MODEL=qwen2.5-coder:7b
CREST_OLLAMA_FAST_MODEL=qwen2.5-coder:7b
CREST_OLLAMA_DEEP_MODEL=qwen2.5-coder:14b

# Offline MiniLM artifacts are generated by app.precompute_embeddings.
CREST_SEMANTIC_ENABLED=true
CREST_SEMANTIC_MODEL=sentence-transformers/all-MiniLM-L6-v2
CREST_SEMANTIC_ARTIFACT_DIR=./data/embeddings

# Leave blank until a public sandbox is approved.
CREST_SANDBOX_URL=
